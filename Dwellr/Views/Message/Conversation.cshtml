@model IEnumerable<Dwellr.Models.Message>
@{
    ViewData["Title"] = "Conversation";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="card shadow-sm">
    <div class="card-header">
        <h5 class="mb-0">Conversation</h5>
    </div>
    <div class="card-body" style="height:400px;overflow-y:auto;">
        @foreach (var m in Model)
        {
            var isMine = m.SenderId == currentUserId;
            <div class="d-flex @(isMine ? "justify-content-end" : "justify-content-start") mb-2">
                <div class="p-3 rounded @(isMine ? "bg-primary text-white" : "bg-light")"
                     style="max-width:70%;">
                    <p class="mb-1">@m.Body</p>
                    <small class="@(isMine ? "text-white-50" : "text-muted")">
                        @m.SentAt.ToString("hh:mm tt")
                    </small>
                </div>
            </div>
        }
    </div>
    <div class="card-footer">
        <form asp-controller="Message" asp-action="Send" method="post">
            <input type="hidden" name="propertyId" value="@ViewBag.PropertyId" />
            <input type="hidden" name="receiverId" value="@ViewBag.OtherUserId" />
            <div class="input-group">
                <input type="text" name="body" class="form-control"
                       placeholder="Type a message..." required />
                <button type="submit" class="btn btn-primary">Send</button>
            </div>
        </form>
    </div>
</div>