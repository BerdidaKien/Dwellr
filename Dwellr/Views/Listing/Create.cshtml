@model Dwellr.Models.Property
@{
    ViewData["Title"] = "Post a Listing";
}

<h2 class="mb-4">Post a New Listing</h2>
<div asp-validation-summary="All" class="alert alert-danger"></div>

<form asp-controller="Listing" asp-action="Create" method="post"
      enctype="multipart/form-data">
    <div class="row g-3">
        <div class="col-md-8">
            <label class="form-label">Title</label>
            <input asp-for="Title" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Property Type</label>
            <select asp-for="Type" class="form-select"
                    asp-items="Html.GetEnumSelectList<Dwellr.Models.PropertyType>()"></select>
        </div>
        <div class="col-12">
            <label class="form-label">Description (min 50 characters)</label>
            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
        </div>
        <div class="col-md-4">
            <label class="form-label">Monthly Price (₱)</label>
            <input asp-for="Price" class="form-control" type="number" />
        </div>
        <div class="col-md-4">
            <label class="form-label">City</label>
            <input asp-for="City" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">District</label>
            <input asp-for="District" class="form-control" />
        </div>
        <div class="col-12">
            <label class="form-label">Full Address</label>
            <input asp-for="Address" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Bedrooms</label>
            <input asp-for="Bedrooms" class="form-control" type="number" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Bathrooms</label>
            <input asp-for="Bathrooms" class="form-control" type="number" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Area (m²)</label>
            <input asp-for="AreaSqM" class="form-control" type="number" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Available From</label>
            <input asp-for="AvailableFrom" class="form-control" type="date" />
        </div>
        <div class="col-12">
            <label class="form-label">Photos (minimum 3 required)</label>
            <input type="file" name="photos" class="form-control"
                   multiple accept="image/*" />
            <small class="text-muted">Hold Ctrl to select multiple photos.</small>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Save as Draft</button>
            <a asp-controller="Listing" asp-action="Index"
               class="btn btn-outline-secondary">Cancel</a>
        </div>
    </div>
</form>