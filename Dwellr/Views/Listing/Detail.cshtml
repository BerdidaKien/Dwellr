@model Dwellr.Models.Property
@{
    ViewData["Title"] = Model.Title;
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index">Home</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-controller="Listing" asp-action="Index">Browse</a>
        </li>
        <li class="breadcrumb-item active">@Model.Title</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-md-8">
        <!-- Photo Carousel -->
        @if (Model.Photos.Any())
        {
            <div id="photoCarousel" class="carousel slide mb-4 rounded overflow-hidden shadow"
                 data-bs-ride="carousel">
                <div class="carousel-inner">
                    @for (int i = 0; i < Model.Photos.Count; i++)
                    {
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <img src="@Model.Photos.ElementAt(i).ImagePath"
                                 class="d-block w-100"
                                 style="height:420px;object-fit:cover;" />
                        </div>
                    }
                </div>
                <button class="carousel-control-prev" type="button"
                        data-bs-target="#photoCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button"
                        data-bs-target="#photoCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
                <div class="carousel-indicators">
                    @for (int i = 0; i < Model.Photos.Count; i++)
                    {
                        <button type="button" data-bs-target="#photoCarousel"
                                data-bs-slide-to="@i"
                                class="@(i == 0 ? "active" : "")"></button>
                    }
                </div>
            </div>
        }

        <!-- Title & Info -->
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <span class="badge bg-primary mb-2">@Model.Type</span>
                <h2 class="fw-bold">@Model.Title</h2>
                <p class="text-muted">
                    📍 @Model.Address, @Model.District, @Model.City
                </p>
            </div>
            <div class="text-end">
                <h3 class="fw-bold text-success">
                    ₱@Model.Price.ToString("N0")
                    <small class="text-muted fs-6">/month</small>
                </h3>
            </div>
        </div>

        <!-- Property Details -->
        <div class="row text-center bg-light rounded p-3 mb-4">
            <div class="col">
                <div class="fw-bold fs-4">@Model.Bedrooms</div>
                <small class="text-muted">🛏 Bedrooms</small>
            </div>
            <div class="col">
                <div class="fw-bold fs-4">@Model.Bathrooms</div>
                <small class="text-muted">🚿 Bathrooms</small>
            </div>
            <div class="col">
                <div class="fw-bold fs-4">@Model.AreaSqM</div>
                <small class="text-muted">📐 m²</small>
            </div>
            <div class="col">
                <div class="fw-bold fs-4">
                    @Model.AvailableFrom.ToString("MMM dd")
                </div>
                <small class="text-muted">📅 Available</small>
            </div>
        </div>

        <!-- Description -->
        <div class="mb-4">
            <h5 class="fw-bold">About this place</h5>
            <p class="text-muted">@Model.Description</p>
        </div>

        <!-- Map -->
        @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
        {
            <div class="mb-4">
                <h5 class="fw-bold mb-3">📍 Location</h5>
                <div id="map" class="rounded shadow"
                     style="height:350px;"></div>
            </div>
        }
        else
        {
            <div class="mb-4">
                <h5 class="fw-bold mb-3">📍 Location</h5>
                <div class="bg-light rounded p-4 text-center text-muted">
                    <p>📍 @Model.District, @Model.City</p>
                    <small>Exact location shown after contacting landlord.</small>
                </div>
            </div>
        }

        <!-- Report -->
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="mb-4">
                <button class="btn btn-outline-danger btn-sm"
                        data-bs-toggle="modal" data-bs-target="#reportModal">
                    🚨 Report this listing
                </button>
            </div>
        }
    </div>

    <!-- Sidebar -->
    <div class="col-md-4">
        <div class="card shadow border-0 p-4 sticky-top" style="top:20px;">
            <h5 class="fw-bold mb-1">Posted by</h5>
            <div class="d-flex align-items-center mb-3">
                <div class="rounded-circle bg-primary text-white d-flex
                            align-items-center justify-content-center me-3"
                     style="width:45px;height:45px;font-size:18px;">
                    @Model.Landlord?.FullName.FirstOrDefault()
                </div>
                <div>
                    <div class="fw-bold">@Model.Landlord?.FullName</div>
                    <small class="text-success">✅ Verified Landlord</small>
                </div>
            </div>
            <hr />

            @if (User.Identity?.IsAuthenticated == true)
            {
                @if (currentUserId != Model.LandlordId)
                {
                    <!-- Save Button -->
                    <form asp-controller="Listing" asp-action="Save"
                          method="post" class="mb-2">
                        <input type="hidden" name="propertyId"
                               value="@Model.PropertyId" />
                        <button type="submit" class="btn btn-outline-danger w-100">
                            ❤️ Save Listing
                        </button>
                    </form>

                    <!-- Rent Now Button -->
                    <a asp-controller="Rental" asp-action="Apply"
                       asp-route-propertyId="@Model.PropertyId"
                       class="btn btn-success w-100 mb-3">
                        🏠 Rent This Property
                    </a>

                    <p class="text-muted small mb-3">
                        🔒 Contact info is hidden. Use the message form below.
                    </p>
                    <form asp-controller="Message" asp-action="Send" method="post">
                        <input type="hidden" name="receiverId"
                               value="@Model.LandlordId" />
                        <input type="hidden" name="propertyId"
                               value="@Model.PropertyId" />
                        <div class="mb-3">
                            <textarea name="body" class="form-control" rows="4"
                              placeholder="Hi, I'm interested in this property...Is it still available?"></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 mb-2">
                            💬 Send Message
                        </button>
                    </form>
                }
                else
                {
                    <div class="alert alert-info small">
                        This is your listing.
                    </div>
                    <form asp-controller="Listing" asp-action="MarkRented"
                          asp-route-id="@Model.PropertyId" method="post">
                        <button type="submit" class="btn btn-warning w-100">
                            🏠 Mark as Rented
                        </button>
                    </form>
                }
            }
            else
            {
                <p class="text-muted small mb-3">
                    🔒 Login to contact the landlord.
                </p>
                <a asp-controller="Account" asp-action="Login"
                   class="btn btn-primary w-100">Login to Contact</a>
                <a asp-controller="Account" asp-action="Register"
                   class="btn btn-outline-primary w-100 mt-2">
                    Create Account
                </a>
            }
        </div>
    </div>
</div>

<!-- Report Modal -->
@if (User.Identity?.IsAuthenticated == true)
{
    <div class="modal fade" id="reportModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">🚨 Report Listing</h5>
                    <button type="button" class="btn-close"
                            data-bs-dismiss="modal"></button>
                </div>
                <form asp-controller="Listing" asp-action="Report" method="post">
                    <div class="modal-body">
                        <input type="hidden" name="propertyId"
                               value="@Model.PropertyId" />
                        <input type="hidden" name="reportedUserId"
                               value="@Model.LandlordId" />
                        <div class="mb-3">
                            <label class="form-label">Reason for reporting</label>
                            <select name="reason" class="form-select">
                                <option>Fake listing</option>
                                <option>Scam/Fraud</option>
                                <option>Incorrect information</option>
                                <option>Inappropriate content</option>
                                <option>Already rented but still listed</option>
                                <option>Other</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-danger">
                            Submit Report
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@if (Model.Latitude.HasValue && Model.Longitude.HasValue)
{
    <link rel="stylesheet"
          href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        var map = L.map('map').setView([@Model.Latitude, @Model.Longitude], 15);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);
        L.marker([@Model.Latitude, @Model.Longitude])
            .addTo(map)
            .bindPopup('<b>@Model.Title</b><br>@Model.District, @Model.City')
            .openPopup();
    </script>
}