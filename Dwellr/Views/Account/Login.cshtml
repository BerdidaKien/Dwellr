@model Dwellr.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm p-4">
            <h2 class="mb-4 text-center">Welcome Back</h2>
            <div asp-validation-summary="All" class="alert alert-danger"></div>
            <form asp-controller="Account" asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input asp-for="Password" class="form-control" type="password" />
                </div>
                <div class="mb-3 form-check">
                    <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                    <label class="form-check-label">Remember me</label>
                </div>
                <button type="submit" class="btn btn-primary w-100">Login</button>
            </form>
            <hr />
            <p class="text-center">
                Don't have an account?
                <a asp-controller="Account" asp-action="Register">Register</a>
            </p>

            @if (System.Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT")
                        == "Development")
            {
                <div class="alert alert-info mt-3 small">
                    <strong>🔐 Demo Credentials:</strong><br />
                    🛡 Admin: admin@dwellr.com / Admin@1234<br />
                    🏠 Landlord: landlord@gmail.com / Landlord2026<br />
                    🔍 Tenant: tenantonly@gmail.com / Tenant2026
                </div>
            }
        </div>
    </div>
</div>