@{
    ViewData["Title"] = "Upload ID";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm p-4">
            <h2 class="mb-4">Upload Verification ID</h2>
            <p class="text-muted">Upload a valid government-issued ID to verify your identity as a landlord.</p>
            <form asp-controller="Account" asp-action="UploadID"
                  method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label">ID Document</label>
                    <input type="file" name="idDocument" class="form-control"
                           accept="image/*,.pdf" required />
                    <small class="text-muted">Accepted: JPG, PNG, PDF</small>
                </div>
                <button type="submit" class="btn btn-primary w-100">Upload ID</button>
            </form>
        </div>
    </div>
</div>